# Database (Supabase PostgreSQL for production, SQLite for local dev)
# Production: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL="file:./dev.db"

# Better Auth
BETTER_AUTH_SECRET="generate-a-strong-random-string-at-least-32-chars"
BETTER_AUTH_URL="http://localhost:3005"
NEXT_PUBLIC_APP_URL="http://localhost:3005"

# Supabase (Storage + Database)
# Get from: https://supabase.com/dashboard → Project Settings → API
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_BUCKET="property-images"

# Resend (Email)
# Get from: https://resend.com/api-keys
RESEND_API_KEY=""
EMAIL_FROM="EstateOS <noreply@yourdomain.com>"

# Seed protection (optional, for /api/seed)
SEED_SECRET=""
